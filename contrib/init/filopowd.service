[Unit]
Description=Filopow's distributed currency daemon
After=network.target

[Service]
User=filopowcore
Group=filopowcore

Type=forking
PIDFile=/var/lib/filopowd/filopowd.pid
ExecStart=/usr/bin/filopowd -daemon -pid=/var/lib/filopowd/filopowd.pid \
-conf=/etc/filopowcore/filopow.conf -datadir=/var/lib/filopowd -disablewallet

Restart=always
PrivateTmp=true
TimeoutStopSec=60s
TimeoutStartSec=2s
StartLimitInterval=120s
StartLimitBurst=5

[Install]
WantedBy=multi-user.target
