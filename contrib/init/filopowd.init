#!/bin/bash
#
#  filopowd The filopow core server.
#
#
# chkconfig: 345 80 20
# description: filopowd
# processname: filopowd
#

# Source function library.
. /etc/init.d/functions

# you can override defaults in /etc/sysconfig/filopowd, see below
if [ -f /etc/sysconfig/filopowd ]; then
        . /etc/sysconfig/filopowd
fi

RETVAL=0

prog=filopowd
# you can override the lockfile via FILOPOWD_LOCKFILE in /etc/sysconfig/filopowd
lockfile=${FILOPOWD_LOCKFILE-/var/lock/subsys/filopowd}

# filopowd defaults to /usr/bin/filopowd, override with FILOPOWD_BIN
filopowd=${FILOPOWD_BIN-/usr/bin/filopowd}

# filopowd opts default to -disablewallet, override with FILOPOWD_OPTS
filopowd_opts=${FILOPOWD_OPTS--disablewallet}

start() {
    echo -n $"Starting $prog: "
    daemon $DAEMONOPTS $filopowd $filopowd_opts
    RETVAL=$?
    echo
    [ $RETVAL -eq 0 ] && touch $lockfile
    return $RETVAL
}

stop() {
    echo -n $"Stopping $prog: "
    killproc $prog
    RETVAL=$?
    echo
    [ $RETVAL -eq 0 ] && rm -f $lockfile
    return $RETVAL
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    status)
        status $prog
        ;;
    restart)
        stop
        start
        ;;
    *)
        echo "Usage: service $prog {start|stop|status|restart}"
        exit 1
        ;;
esac
